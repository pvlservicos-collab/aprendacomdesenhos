{
  "buildCommand": null,
  "installCommand": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/b", "destination": "/index-b" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(webp|png|jpg|svg|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
